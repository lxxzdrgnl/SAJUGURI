# LLM Provider ("gemini" | "openai" | "claude", 기본: gemini)
LLM_PROVIDER=gemini

GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Embedding (RAG용)
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-001

# ChromaDB — backend/chroma_db 에 재인덱싱 후 ./chroma_db 로 변경
CHROMA_PATH=../mcp-servers/saju-rag/chroma_db

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sajunara

PORT=8000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 프로덕션: https://yourdomain.com/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# 프로덕션: https://yourdomain.com
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# 프로덕션 (nginx HTTPS 리버스 프록시 환경)에서 반드시 true로 설정
# — SessionMiddleware 쿠키에 Secure 플래그 추가
HTTPS_ONLY=false
